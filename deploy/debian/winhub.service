[Unit]
Description=WinHUB production server
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=simple
User=winhub
Group=winhub
WorkingDirectory=/opt/winhub
EnvironmentFile=/etc/winhub/winhub.env
ExecStart=/opt/winhub/venv/bin/python /opt/winhub/server_debian.py
Restart=always
RestartSec=5
KillSignal=SIGTERM
TimeoutStopSec=30
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/var/lib/winhub /var/log/winhub /etc/winhub/certs

[Install]
WantedBy=multi-user.target
