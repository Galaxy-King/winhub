WINHUB_ENV=production
SECRET_KEY=replace-with-64-random-characters

# Server runtime
HOST=127.0.0.1
PORT=8443
DATA_DIR=/var/lib/winhub
NEWSLETTER_DATA_DIR=/var/lib/winhub/newsletter
SERVER_LOG_FILE=/var/log/winhub/winhub_prod.log
SERVER_CERT_PATH=/etc/winhub/certs/cert.pem
SERVER_KEY_PATH=/etc/winhub/certs/key.pem

# PostgreSQL
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=winhub
POSTGRES_USER=winhub
POSTGRES_PASSWORD=replace-with-strong-db-password

# Security / sessions
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Strict
SESSION_IDLE_TIMEOUT_SECONDS=21600
SESSION_ABSOLUTE_TIMEOUT_SECONDS=0
HSTS_ENABLED=true

# Rate limiting. Keep memory:// for simple single-service deployment.
RATELIMIT_STORAGE_URI=memory://
RATELIMIT_DEFAULT=
LOGIN_RATE_LIMIT=5 per minute
AGENT_ENROLLMENT_RATE_LIMIT=10 per minute

# Agent enrollment and task signing
AGENT_API_KEY=replace-with-long-random-enrollment-secret
AGENT_ENROLLMENT_ENABLED=true
AGENT_ENROLLMENT_ALLOWLIST=
AGENT_ALLOW_REENROLL_EXISTING=false
AGENT_TASK_HMAC_SECRET=replace-with-different-long-random-hmac-secret
AGENT_MAX_RESULT_LOG_BYTES=262144
AGENT_TASK_TIMEOUT_SECONDS=1800
AGENT_PACKAGE_MAX_UPLOAD_MB=256
LATEST_AGENT_VERSION=1.2.0

# Retention
LOG_RETENTION_DAYS=30
AUDIT_RETENTION_DAYS=365

# Mail / GPG for admin notifications
SENDER_EMAIL=admin@example.com
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_PASSWORD=
GPG_PATH=/usr/bin/gpg
GPG_HOME=/var/lib/winhub/gnupg
